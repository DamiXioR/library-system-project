# REQUIRED ENVIRONMENT VARIABLES
export LIBSYS_ENV_LOADED=false

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"

if [ -z "$REPO_ROOT" ]; then
    echo "Error: not inside a git repository"
    return 1
fi

export REPO_ROOT

export APP_DIR_NAME="app"
export APP_PATH="${REPO_ROOT}/${APP_DIR_NAME}"

export MAIN_LOGS_FILE_NAME="LibrarySystemMainLogs.log"
export LOGS_DIR_NAME="logs"
export LOG_PATH="${REPO_ROOT}/${LOGS_DIR_NAME}/${MAIN_LOGS_FILE_NAME}"

export LIBSYS_ENV_LOADED=true
